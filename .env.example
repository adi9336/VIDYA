# App
NODE_ENV=development
PORT=3000

# OpenAI
OPENAI_API_KEY=
MODEL_PROVIDER=openai
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_TIMEOUT_MS=60000
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=cedar

# Local fallback providers
SPEECH_TO_TEXT_PROVIDER=openai
TEXT_TO_SPEECH_PROVIDER=openai
VISUAL_GENERATION_PROVIDER=openai

# ElevenLabs fallback
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# LiveKit realtime mode
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit agent provider keys
DEEPGRAM_API_KEY=

# LiveKit supervisor orchestration
VIDYA_ROUTER_MODEL=gpt-5-mini
VIDYA_REPLY_MODEL=gpt-5.2
VIDYA_ROUTER_TIMEOUT_MS=2500
VIDYA_REPLY_TIMEOUT_MS=12000
VIDYA_ENABLE_VISUAL_EVENTS=true

